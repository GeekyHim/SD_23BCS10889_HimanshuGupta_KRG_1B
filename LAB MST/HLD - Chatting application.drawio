        </mxCell>
        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;DAU - 2 million&lt;/div&gt;Availabilty &amp;gt;&amp;gt; Consistency&lt;div&gt;Delay should be very low (100 ms)&lt;/div&gt;&lt;div&gt;system should be highly reliable&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="300" x="50" y="290" as="geometry" />
        </mxCell>
        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="user&lt;div&gt;messages&lt;/div&gt;&lt;div&gt;groups&lt;/div&gt;" vertex="1">

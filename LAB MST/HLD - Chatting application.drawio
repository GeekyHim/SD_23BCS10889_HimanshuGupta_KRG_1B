        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;1. Register / Login&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;post/api/v1/user/login&lt;/div&gt;&lt;div&gt;post/api/v1/user/register&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="220" x="50" y="535" as="geometry" />
        </mxCell>
        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;2. Send message using websockets&lt;/b&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;websocket --&amp;gt; WS/send/msg&lt;/div&gt;&lt;div&gt;post/api/v1/send/{user1}/{user2}&lt;/div&gt;&lt;div&gt;post/api/v1/send/{user1}/{grp1}&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="305" x="50" y="620" as="geometry" />
        </mxCell>
        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;3. Get message&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;web socket - WS/chat/msg&lt;/div&gt;&lt;div&gt;get/api/v1/chat/{user1}/{user2}&lt;/div&gt;&lt;div&gt;get/api/v1/chat/{user1}/{grp1}&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="305" x="50" y="720" as="geometry" />
        </mxCell>
        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-16" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;4. Groups&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;create a group&lt;/div&gt;&lt;div&gt;post/group/create&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;add a member&lt;/div&gt;&lt;div&gt;post/group/add/{user_id}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;remove a user&lt;/div&gt;&lt;div&gt;delete/group/user/{user_id}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;delete a group&lt;/div&gt;&lt;div&gt;delete/group/{group_id}&lt;/div&gt;" vertex="1">

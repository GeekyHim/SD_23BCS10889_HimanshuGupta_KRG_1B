        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;u&gt;CORE ENTITIES&lt;/u&gt;&lt;/b&gt;" vertex="1">

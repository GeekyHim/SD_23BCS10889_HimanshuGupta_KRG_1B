        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;u&gt;&lt;b&gt;FUNCTIONAL REQUIREMENTS&lt;/b&gt;&lt;/u&gt;" vertex="1">
          <mxGeometry height="30" width="230" x="50" y="70" as="geometry" />
        </mxCell>
        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="- user should be able to login using mobile number&lt;div&gt;&lt;div&gt;- send messages to contacts (one to one)&lt;/div&gt;&lt;/div&gt;&lt;div&gt;- recieve messages from contact&lt;/div&gt;&lt;div&gt;- push notification from contacts&lt;/div&gt;&lt;div&gt;- user should be able to create groups and message in them&lt;/div&gt;&lt;div&gt;- user should be able to send images and videos&lt;/div&gt;&lt;div&gt;- user should be able to see chat history&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="300" x="50" y="150" as="geometry" />
        </mxCell>
        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;u&gt;&lt;b&gt;NON FUNCTIONAL REQUIREMENTS&lt;/b&gt;&lt;/u&gt;" vertex="1">

        <mxCell id="ppnwwOGjGj9Z3vF_vXnV-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;u&gt;&lt;b&gt;API ENDPOINTS&lt;/b&gt;&lt;/u&gt;" vertex="1">
